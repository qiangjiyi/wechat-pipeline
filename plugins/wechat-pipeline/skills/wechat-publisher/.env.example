WECHAT_PROXY_URL=
WECHAT_API_BASE=https://api.weixin.qq.com

# Comma-separated account aliases. Aliases map to WECHAT_<ALIAS>_APP_ID and
# WECHAT_<ALIAS>_APP_SECRET after uppercasing and replacing non-alphanumerics
# with underscores.
WECHAT_ACCOUNTS=personal,company

WECHAT_PERSONAL_APP_ID=
WECHAT_PERSONAL_APP_SECRET=
WECHAT_PERSONAL_ACCESS_TOKEN=

WECHAT_COMPANY_APP_ID=
WECHAT_COMPANY_APP_SECRET=
WECHAT_COMPANY_ACCESS_TOKEN=

# Single-account fallback when WECHAT_ACCOUNTS is empty.
WECHAT_APP_ID=
WECHAT_APP_SECRET=
WECHAT_ACCESS_TOKEN=
